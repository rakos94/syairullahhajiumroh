                                "$ref": "#/definitions/model.Jamaah"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Membuat data jamaah haji/umroh baru",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jamaah"
                ],
                "summary": "Tambah jamaah baru",
                "parameters": [
                    {
                        "description": "Data jamaah",
                        "name": "jamaah",
