        "/jamaah/{id}": {
            "get": {
                "description": "Menampilkan detail jamaah berdasarkan ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jamaah"
                ],
                "summary": "Detail jamaah",
                "parameters": [
