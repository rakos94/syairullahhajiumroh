        "/jamaah/{id}/dokumen/{docType}": {
            "get": {
                "description": "Download file dokumen jamaah berdasarkan tipe",
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "dokumen"
                ],
                "summary": "Download dokumen jamaah",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Jamaah ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "enum": [
                            "ktp",
                            "kk",
                            "paspor",
                            "pasfoto",
                            "koper_diterima"
                        ],
                        "type": "string",
                        "description": "Tipe dokumen",
                        "name": "docType",
                        "in": "path",
                        "required": true
