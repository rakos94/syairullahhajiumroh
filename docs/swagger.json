                "nama",
                "nik",
                "paket",
                "status_pembayaran"
            ],
            "properties": {
                "alamat": {
                    "type": "string"
                },
                "batik_kbih_sudah_diterima": {
                    "type": "boolean"
                },
                "batik_nasional_sudah_dijahit": {
                    "type": "boolean"
                },
                "created_at": {
                    "type": "string"
                },
                "foto_kk": {
                    "type": "string"
                },
                "foto_koper_diterima": {
                    "type": "string"
                },
                "foto_ktp": {
                    "type": "string"
                },
                "foto_paspor": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "jenis_kelamin": {
                    "type": "string",
                    "enum": [
                        "laki-laki",
                        "perempuan"
                    ]
                },
                "keterangan": {
                    "type": "string"
                },
                "koper_sudah_diterima": {
                    "type": "boolean"
                },
                "nama": {
                    "type": "string"
                },
                "nik": {
                    "type": "string"
                },
                "no_hp": {
                    "type": "string"
                },
                "no_rekening_haji": {
                    "type": "string"
                },
                "nomor_paspor": {
                    "type": "string"
                },
                "paket": {
                    "type": "string",
                    "enum": [
                        "haji",
                        "umroh"
                    ]
                },
                "pasfoto": {
                    "type": "string"
                },
                "status_pembayaran": {
                    "type": "string",
                    "enum": [
                        "belum_bayar",
                        "dp",
                        "lunas"
                    ]
                },
                "tanggal_keberangkatan": {
                    "type": "string"
                },
                "tanggal_lahir": {
                    "type": "string"
                },
                "tipe_bank": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        }
