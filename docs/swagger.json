                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Data jamaah",
                        "name": "jamaah",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Jamaah"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
