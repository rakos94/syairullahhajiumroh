                "description": "Menampilkan daftar jamaah, bisa difilter berdasarkan paket",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jamaah"
                ],
                "summary": "List semua jamaah",
                "parameters": [
                    {
                        "enum": [
                            "haji",
                            "umroh"
                        ],
                        "type": "string",
                        "description": "Filter berdasarkan paket",
                        "name": "paket",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
