            "post": {
                "description": "Upload file dokumen (KTP, KK, Paspor, Pasfoto, Koper Diterima) untuk jamaah",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "dokumen"
                ],
                "summary": "Upload dokumen jamaah",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Jamaah ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "enum": [
                            "ktp",
                            "kk",
                            "paspor",
                            "pasfoto",
                            "koper_diterima"
                        ],
                        "type": "string",
                        "description": "Tipe dokumen",
                        "name": "docType",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "File dokumen (jpg, jpeg, png, pdf)",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
